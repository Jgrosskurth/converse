{
  "templates": [
    {
      "name": "homepage",
      "urls": [
        "https://www.academy.com/"
      ],
      "description": "Academy Sports + Outdoors homepage with featured categories, promotions, and brand content",
      "blocks": [
        {
          "name": "hero",
          "instances": [
            "div[class*='heroCarousel'], div[class*='hero-carousel']",
            "div:has(a[href*='baseball'])"
          ]
        },
        {
          "name": "cards",
          "instances": [
            "div[data-testid*='productCarousel']:nth-of-type(1), div[class*='carousel']:has(h2)",
            "div[data-testid*='productCarousel']:nth-of-type(2)",
            "div[data-testid*='productCarousel']:nth-of-type(3)",
            "div[data-testid*='productCarousel']:nth-of-type(4)",
            "div[class*='brandCarousel'], div:has(> a[href*='running-shoes'])",
            "div[class*='newFinds'], div:has(a[href*='casual-shoes'])",
            "div:has(img[alt*='Brazos brand logo'])",
            "div:has(h3:has-text('$15 OFF AFTER YOU JOIN'))"
          ]
        },
        {
          "name": "columns",
          "instances": [
            "div:has(a[href*='ariat'])",
            "div:has(a[href*='mlb'])",
            "div:has(img[alt*='myAcademy Rewards'])",
            "div:has(img[alt='Academy Sports'])"
          ]
        }
      ],
      "sections": [
        {
          "id": "section-promo-banner",
          "name": "Promotional Banner",
          "selector": "section[aria-label='Buy More, Save More']",
          "style": "dark",
          "blocks": [],
          "defaultContent": [
            "section[aria-label='Buy More, Save More'] a img"
          ]
        },
        {
          "id": "section-hero-carousel",
          "name": "Hero Carousel",
          "selector": "div[class*='heroCarousel'], div[class*='hero-carousel']",
          "style": null,
          "blocks": [
            "hero"
          ],
          "defaultContent": []
        },
        {
          "id": "section-price-match",
          "name": "Price Match Guarantee",
          "selector": "a[href='/price-match-guarantee']",
          "style": null,
          "blocks": [],
          "defaultContent": [
            "a[href='/price-match-guarantee'] img"
          ]
        },
        {
          "id": "section-product-carousels",
          "name": "Product Carousels",
          "selector": "div[data-testid*='productCarousel']",
          "style": null,
          "blocks": [
            "cards"
          ],
          "defaultContent": []
        },
        {
          "id": "section-running-shoes",
          "name": "Running Shoes Brand Showcase",
          "selector": "div:has(> a[href*='running-shoes'])",
          "style": "light-gray",
          "blocks": [
            "cards"
          ],
          "defaultContent": [
            "div:has(> a[href*='running-shoes']) h2"
          ]
        },
        {
          "id": "section-new-finds",
          "name": "New Finds / Color Drops",
          "selector": "div:has(> img[alt*='NEW FINDS'])",
          "style": null,
          "blocks": [
            "cards"
          ],
          "defaultContent": [
            "div:has(> img[alt*='NEW FINDS']) > *:first-child"
          ]
        },
        {
          "id": "section-soccer",
          "name": "Soccer Promo",
          "selector": "a[href*='usa-soccer-gear']",
          "style": "dark",
          "blocks": [],
          "defaultContent": [
            "a[href*='usa-soccer-gear'] img"
          ]
        },
        {
          "id": "section-clearance",
          "name": "Clearance Banner",
          "selector": "a[href*='clearance']",
          "style": "yellow",
          "blocks": [],
          "defaultContent": [
            "a[href*='clearance'] img"
          ]
        },
        {
          "id": "section-baseball",
          "name": "Baseball Promo",
          "selector": "div:has(a[href*='baseball'])",
          "style": "dark",
          "blocks": [
            "hero"
          ],
          "defaultContent": []
        },
        {
          "id": "section-workwear",
          "name": "Workwear",
          "selector": [
            "section[aria-label*='workwear']",
            "a[href*='workwear']"
          ],
          "style": "yellow",
          "blocks": [
            "columns",
            "cards"
          ],
          "defaultContent": [
            "h3:has-text('LOOKING FOR MORE BRANDS')",
            "a[href*='workwear'] img"
          ]
        },
        {
          "id": "section-fan-shop",
          "name": "Trending for Fans",
          "selector": "div:has(> img[alt*='TRENDING'])",
          "style": null,
          "blocks": [
            "columns"
          ],
          "defaultContent": [
            "div:has(> img[alt*='TRENDING']) > *:first-child"
          ]
        },
        {
          "id": "section-rewards",
          "name": "More Savings / Rewards",
          "selector": "div:has(img[alt*='myAcademy Rewards'])",
          "style": "academy-red",
          "blocks": [
            "columns"
          ],
          "defaultContent": []
        },
        {
          "id": "section-app-card-text",
          "name": "App / Credit Card / Text Signup",
          "selector": "div:has(img[alt='Academy Sports'])",
          "style": null,
          "blocks": [
            "columns"
          ],
          "defaultContent": []
        },
        {
          "id": "section-service-features",
          "name": "Service Features",
          "selector": "div:has(h3:has-text('$15 OFF AFTER YOU JOIN'))",
          "style": "light-gray",
          "blocks": [
            "cards"
          ],
          "defaultContent": []
        }
      ]
    }
  ]
}